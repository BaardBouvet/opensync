{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["src/**/*.test.ts"],
  "references": [
    { "path": "../packages/sdk" },
    { "path": "../packages/engine" }
  ]
}
